# ══════════════════════════════════════════════════════════
#  Stake AutoBot — Environment Configuration
#  Copy to .env and fill in your values:
#    cp .env.example .env && nano .env
# ══════════════════════════════════════════════════════════

# ── Stake Auth ─────────────────────────────────────────
# Get these from browser DevTools (F12 → Network tab → any stake.com request)
# x-access-token header value
STAKE_ACCESS_TOKEN=

# x-lockdown-token header value
STAKE_LOCKDOWN_TOKEN=

# Optional: Cloudflare cookie (cf_clearance) — only needed on servers
# STAKE_COOKIE=

# ── File Paths (optional, sensible defaults) ─────────────
# STAKE_DB_PATH=~/.stake_autobot.db
# STAKE_CONFIG_PATH=~/.stake_autobot.json
# STAKE_STATE_PATH=~/.stake_autobot_live.json
# STAKE_PID_PATH=~/.stake_autobot.pid
# STAKE_PRESET_PATH=~/.stake_presets.json
# STAKE_LOG_DIR=~/.stake_logs

# ── Cloudflare Bypass (server only) ─────────────────────
# FlareSolverr URL (auto-detected if running on localhost)
# FLARESOLVERR_URL=http://localhost:8191/v1

# ── Telegram Bot ─────────────────────────────────────────
# Get this from @BotFather on Telegram (see setup guide below)
STAKE_TG_TOKEN=

# Directory for per-user Telegram data (DB, config, presets)
# Default: ~/.stakebot_tg
# STAKE_TG_DATA=~/.stakebot_tg

# ══════════════════════════════════════════════════════════
#  TELEGRAM SETUP GUIDE
# ══════════════════════════════════════════════════════════
#
#  1. Open Telegram and search for @BotFather
#  2. Send /newbot
#  3. Choose a display name (e.g. "Stake AutoBot")
#  4. Choose a username (must end in "bot", e.g. "stake_autobot_bot")
#  5. BotFather replies with your bot token — paste it above
#  6. Optional: Send /setdescription to BotFather to set a description
#  7. Optional: Send /setcommands to BotFather and paste:
#
#     start - Show welcome and quick start guide
#     help - Full command reference
#     settoken - Set Stake access tokens
#     balance - Check balances
#     config - View current config
#     set - Set a parameter
#     strategies - List strategies
#     bet - Start betting session
#     stop - Stop session
#     pause - Pause betting
#     resume - Resume betting
#     status - Live status with refresh button
#     monitor - Auto-updating live status
#     stats - Session history
#     lastbets - Recent bets
#     session - Detailed session report
#     rules - List current rules
#     addrule - Add a rule (JSON)
#     clearrules - Clear all rules
#     presets - List presets
#     savepreset - Save current config as preset
#     loadpreset - Load a preset
#
# ══════════════════════════════════════════════════════════
