# Stake Admin Web App — Configuration
# Copy to .env and customize

STAKE_WEB_SECRET_KEY=change-me-to-a-random-64-char-string
STAKE_WEB_ADMIN_USER=admin
STAKE_WEB_ADMIN_PASS=changeme123
STAKE_WEB_HOST=127.0.0.1
STAKE_WEB_PORT=8001
STAKE_WEB_DEBUG=false

# Paths (defaults usually work)
# STAKE_WEB_DB_PATH=~/.stake_web.db
# STAKE_WEB_BOT_DATA_DIR=~/.stakebot_tg
# STAKE_WEB_INSTALL_DIR=~/stake-bot
# STAKE_WEB_REPO_DIR=~/stake

# Service names
# STAKE_WEB_SERVICE_CLI=stake
# STAKE_WEB_SERVICE_TG=stake-tg
# STAKE_WEB_SERVICE_WEB=stake-web

# Telegram (optional — for generating auth deep links)
# STAKE_WEB_TG_BOT_TOKEN=
